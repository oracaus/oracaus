{
  "name": "oracaus",
  "version": "0.5.0-pre",
  "description": "Compute-quantum render alignment for heavy local compute against streaming inputs in React. Monorepo root.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "scripts": {
    "test": "vitest run",
    "test:memory": "NODE_OPTIONS='--expose-gc' vitest run",
    "bench": "vitest bench",
    "bench:memory": "node --expose-gc ./node_modules/.bin/vitest bench",
    "typecheck": "tsc --build && npm run typecheck --workspaces --if-present",
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "demo:prod": "npm run -w @oracaus/demo build && npm run -w @oracaus/demo preview",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx biome check --staged --no-errors-on-unmatched"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [],
  "author": "Przemyslaw Kalka",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
